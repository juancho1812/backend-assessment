{
  "name": "juan-backend-assessment",
  "version": "1.0.0",
  "description": "In-memory transactions service | Meaningful backend assessment",
  "private": true,
  "license": "UNLICENSED",
  "author": "Juan Méndez",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "smoke": "pnpm build && node scripts/smoke.js",
    "load": "pnpm build && node scripts/load.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"{src,test}/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@fastify/type-provider-zod": "^1.0.0",
    "fastify": "^5.8.5",
    "zod": "^4.3.6"
  }
}
